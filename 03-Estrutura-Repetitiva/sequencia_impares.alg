Algoritmo "sequencia_impares"

// Autor(a): Daniel Pedroso
// Data: 10/04/2026

Var
// Seção de Declarações das variáveis
 x, i: inteiro


Inicio
// Seção de Comandos
 escreva ("Digite o valor de X: ")
 leia (x)
 escreval (x)
 
 
 para i de 1 ate x faca 
  se i % 2 <> 0 entao
    escreval (i)
  fimse
  
 fimpara
 
fimalgoritmo