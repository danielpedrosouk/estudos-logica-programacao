Algoritmo "circulo"

// Disciplina: Logica da programacao
// Autor(a): Daniel Pedroso
// Data: 12/03/2026

Var
// Seção de Declarações das variáveis
 r, area : real

Inicio
// Seção de Comandos
 escreva ("Digite o valor do raio do circulo: ")
 leia (r)
 escreval (r)
 
 area <- 3.14159 * r * r
 
 escreva ("AREA = ", area:8:3)


fimalgoritmo
